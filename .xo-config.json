{
  "rules": {
    "@typescript-eslint/naming-convention": [
      "error",
      {
        "selector": "variable",
        "modifiers": ["const", "global", "exported"],
        "format": ["UPPER_CASE", "strictCamelCase"]
      }
    ],
    "@typescript-eslint/consistent-type-definitions": "off",
    "@typescript-eslint/ban-types": "off",
    "no-await-in-loop": "off"
  }
}
